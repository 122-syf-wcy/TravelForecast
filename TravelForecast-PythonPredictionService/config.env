# Python 预测服务配置文件示例

# 服务配置
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8001
DEBUG=True

# 数据库配置（连接Java后端的MySQL）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=travel_prediction

# 模型配置
MODEL_PATH=./models
DATA_PATH=./data

# 日志配置
LOG_LEVEL=INFO
LOG_PATH=./logs

# API密钥（可选，用于服务间认证）
API_SECRET_KEY=your-secret-key-here

