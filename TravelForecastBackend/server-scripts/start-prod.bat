@echo off
REM ============================================================================
REM 旅游预测服务 - 生产环境启动脚本
REM 在服务器上使用此脚本启动应用
REM ============================================================================

chcp 65001 >nul
cd /d %~dp0..

echo.
echo ╔════════════════════════════════════════════════════════════════════════╗
echo ║                启动旅游预测服务（生产环境）                             ║
echo ╚════════════════════════════════════════════════════════════════════════╝
echo.

REM ============================================================================
REM 检查JAR包是否存在
REM ============================================================================
if not exist "travel-prediction-1.0.0.jar" (
    echo ❌ 错误: JAR包不存在
    echo 请确保 travel-prediction-1.0.0.jar 在当前目录
    pause
    exit /b 1
)

REM ============================================================================
REM 检查配置文件是否存在
REM ============================================================================
if not exist "config\application-prod.yml" (
    echo ⚠️ 警告: 配置文件不存在 (config\application-prod.yml)
    echo 将使用默认配置
    echo.
)

REM ============================================================================
REM 检查日志目录
REM ============================================================================
if not exist "C:\logs" (
    mkdir C:\logs
    echo ✓ 日志目录已创建: C:\logs
)

REM ============================================================================
REM 设置JVM参数
REM ============================================================================
set JAVA_OPTS=-Xms512m -Xmx1024m -Dfile.encoding=UTF-8

REM ============================================================================
REM 启动应用
REM ============================================================================
echo 📋 启动信息:
echo    JVM 参数: %JAVA_OPTS%
echo    活跃配置: prod（生产环境）
echo    配置文件: config/application-prod.yml
echo    日志位置: C:/logs/travel-prediction.log
echo.
echo 🚀 正在启动应用...
echo.

java %JAVA_OPTS% ^
  -Dspring.profiles.active=prod ^
  -Dspring.config.location=file:config/application-prod.yml ^
  -jar travel-prediction-1.0.0.jar

REM ============================================================================
REM 如果Java进程结束，显示退出信息
REM ============================================================================
echo.
echo ❌ 应用已停止
echo.
echo 👉 查看日志获取更多信息:
echo    type C:\logs\travel-prediction.log
echo.
pause


