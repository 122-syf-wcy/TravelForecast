# ============================================================
# 智教黔行 · 环境变量模板
# 复制此文件为 .env 并填入真实值
# .env 文件已在 .gitignore 中排除，不会被提交
# ============================================================

# 数据库
DB_HOST=localhost
DB_PORT=3306
DB_NAME=travel_prediction
DB_USER=root
DB_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT密钥
JWT_SECRET=

# 阿里云OSS
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# 通义千问 (DashScope)
DASHSCOPE_API_KEY=

# 高德地图
AMAP_API_KEY=

# 邮件
MAIL_USERNAME=
MAIL_AUTH_CODE=

# 微信小程序
WECHAT_APPID=
WECHAT_APPSECRET=

# 数字人 (DeepSeek)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
